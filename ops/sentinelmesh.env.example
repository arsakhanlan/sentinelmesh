# SentinelMesh — production environment template.
#
# On the VM, copy this to /etc/sentinelmesh.env, lock it down with `chmod 600`,
# and fill in every value. The compose stack will refuse to start if anything
# is missing or empty — that's intentional, no defaults make it past prod.
#
#   sudo cp ops/sentinelmesh.env.example /etc/sentinelmesh.env
#   sudo chmod 600 /etc/sentinelmesh.env
#   sudo nano /etc/sentinelmesh.env
#
# Generate strong secrets with:  openssl rand -hex 32

# ----------------------------------------------------------------------------
# Domain (must already resolve to this VM's public IP, both for
# sentinel.<domain> and skynest.<domain>).
# ----------------------------------------------------------------------------
SM_DOMAIN=your-domain.example
SM_ACME_EMAIL=you@your-domain.example

# CORS allow-list. Both production hostnames, comma-separated.
SENTINELMESH_CORS_ALLOWED_ORIGINS=https://sentinel.your-domain.example,https://skynest.your-domain.example

# ----------------------------------------------------------------------------
# Postgres
# ----------------------------------------------------------------------------
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=REPLACE_ME_with_openssl_rand_hex_32

# ----------------------------------------------------------------------------
# SentinelMesh API keys.
#
# - SENTINELMESH_API_KEY        privileged key the AGENT SERVICE uses for
#                               internal calls (planner, executor, audit).
# - SENTINELMESH_ACME_API_KEY   second seed tenant for the budget-runaway demo.
# - SENTINELMESH_PUBLIC_DEMO_KEY  the key Caddy injects for anonymous SOC
#                               visitors. Low daily cap; rate-limited at proxy.
# - SENTINELMESH_JWT_SECRET     used to sign capability tokens.
# ----------------------------------------------------------------------------
SENTINELMESH_API_KEY=REPLACE_ME_with_openssl_rand_hex_32
SENTINELMESH_ACME_API_KEY=REPLACE_ME_with_openssl_rand_hex_32
SENTINELMESH_PUBLIC_DEMO_KEY=REPLACE_ME_with_openssl_rand_hex_32
SENTINELMESH_JWT_SECRET=REPLACE_ME_with_openssl_rand_hex_64

# Public demo mode: the public-demo tenant gets a tighter capability budget
# and slightly trimmed defaults. Leave true on the public deployment.
SENTINELMESH_PUBLIC_DEMO_MODE=true

# ----------------------------------------------------------------------------
# LLM — DeepSeek (OpenAI-compatible). The same keys are used by the
# backend's L4 LLM judge AND the agents' planner/executor.
# ----------------------------------------------------------------------------
SENTINELMESH_L4_PROVIDER=openai
AGENT_LLM_MODE=openai
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=sk-deepseek-REPLACE_ME
OPENAI_MODEL=deepseek-chat
AGENT_TEMPERATURE=0.2

# Azure Content Safety / Prompt Shields stay stubbed unless you have keys.
# (L1 regex + L4 judge cover the same ground when these are blank.)
SENTINELMESH_AZURE_MODE=stub
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_KEY=

# ----------------------------------------------------------------------------
# Caddy admin endpoint protection.
#
# Generate the bcrypt hash:
#   docker run --rm caddy:2.8-alpine caddy hash-password --plaintext 'a-strong-password'
#
# Caddy sees this value verbatim — escape any `$` as `$$` if you put it inline,
# or use the env-substitution form below (no escaping needed).
# ----------------------------------------------------------------------------
SM_ADMIN_BASIC_AUTH=REPLACE_ME_with_caddy_bcrypt_hash
